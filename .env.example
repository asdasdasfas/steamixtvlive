# Upstash Redis — https://upstash.com (Free tier)
# 1. upstash.com'a kaydol
# 2. Yeni bir Redis database oluştur (free tier)
# 3. REST API bölümünden URL ve Token'ı al
# 4. Netlify → Site Settings → Environment variables'a ekle
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
